<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvPatternDialogHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/security_pattern_draw_new"
        android:textColor="@color/app_on_surface"
        android:textSize="14sp" />

    <com.example.galerinio.presentation.ui.widget.PatternLockView
        android:id="@+id/patternDialogView"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_marginTop="8dp"
        android:background="#20000000" />

    <Button
        android:id="@+id/btnClearPattern"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/security_clear_pattern" />
</LinearLayout>


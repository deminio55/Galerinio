<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/drawer_surface">

    <!-- Sync All button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSyncAll"
        style="@style/Widget.Galerinio.Cloud.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:text="@string/cloud_sync_now"
        android:textAllCaps="false" />

    <!-- Account list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCloudAccounts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Add Account button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddAccount"
        style="@style/Widget.Galerinio.Cloud.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:text="@string/cloud_add_account"
        android:textAllCaps="false" />

</LinearLayout>

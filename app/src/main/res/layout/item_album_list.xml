<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingTop="6dp"
    android:paddingEnd="8dp"
    android:paddingBottom="6dp">

    <FrameLayout
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_marginEnd="10dp">

        <ImageView
            android:id="@+id/albumCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/media_item_border"
            android:contentDescription="@string/album_cover"
            android:scaleType="centerCrop" />

        <View
            android:id="@+id/blurOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#77000000"
            android:visibility="gone" />

        <View
            android:id="@+id/editModeOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/album_edit_mode_overlay"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/reorderHintIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="4dp"
            android:background="#66000000"
            android:contentDescription="@string/folders_reorder_edit"
            android:padding="2dp"
            android:src="@drawable/ic_reorder_24"
            android:visibility="gone"
            app:tint="@android:color/white" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/albumName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/app_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mediaCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/app_on_surface_secondary"
            android:textSize="13sp" />
    </LinearLayout>

    <ImageView
        android:id="@+id/protectionIcon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:background="#33000000"
        android:clickable="true"
        android:contentDescription="@string/security_enable_folder_protection"
        android:focusable="true"
        android:padding="4dp"
        android:src="@drawable/ic_lock_24"
        app:tint="@android:color/white" />

</LinearLayout>


<?xml version="1.0" encoding="utf-8"?>
<com.example.galerinio.presentation.ui.widget.SquareFrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="1dp"
    android:background="@android:color/black"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/albumCover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@string/album_cover"
        android:scaleType="centerCrop"
        android:background="@drawable/media_item_border" />

    <View
        android:id="@+id/blurOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#77000000"
        android:visibility="gone" />

    <View
        android:id="@+id/editModeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/album_edit_mode_overlay"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/reorderHintIcon"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="#66000000"
        android:contentDescription="@string/folders_reorder_edit"
        android:padding="2dp"
        android:src="@drawable/ic_reorder_24"
        app:tint="@android:color/white"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/protectionIcon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="6dp"
        android:layout_marginTop="6dp"
        android:background="#66000000"
        android:contentDescription="@string/security_enable_folder_protection"
        android:clickable="true"
        android:focusable="true"
        android:padding="4dp"
        android:src="@drawable/ic_lock_24"
        android:visibility="gone"
        app:tint="@android:color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#99000000"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/albumName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mediaCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="#E6FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

</com.example.galerinio.presentation.ui.widget.SquareFrameLayout>


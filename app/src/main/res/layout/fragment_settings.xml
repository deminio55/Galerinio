<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/drawer_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/security_section_title"
            android:textColor="@color/app_on_surface"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/security_section_desc"
            android:textColor="@color/app_on_surface_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/security_enable_app_lock"
                android:textColor="@color/app_on_surface"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchAppLock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAppLockHelper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/security_select_method_to_activate"
            android:textColor="@color/app_on_surface_secondary"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/appMethodsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/security_app_unlock_method"
                android:textColor="@color/app_on_surface"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgAppMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/radioAppPin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_pin" />

                <RadioButton
                    android:id="@+id/radioAppPattern"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_pattern" />

                <RadioButton
                    android:id="@+id/radioAppBiometric"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_biometric" />
            </RadioGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/security_enable_folder_protection"
                android:textColor="@color/app_on_surface"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchFolderProtection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvFolderProtectionHelper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/security_select_method_to_activate"
            android:textColor="@color/app_on_surface_secondary"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/folderMethodsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/security_folder_unlock_method"
                android:textColor="@color/app_on_surface"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgFolderMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <RadioButton
                    android:id="@+id/radioFolderPin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_pin" />

                <RadioButton
                    android:id="@+id/radioFolderPattern"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_pattern" />

                <RadioButton
                    android:id="@+id/radioFolderBiometric"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_biometric" />
            </RadioGroup>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/protectedMediaModeContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvProtectedMediaModeTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/security_protected_media_mode"
                android:textColor="@color/app_on_surface"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgProtectedMediaMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <RadioButton
                    android:id="@+id/radioProtectedMediaHide"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_protected_media_mode_hide" />

                <RadioButton
                    android:id="@+id/radioProtectedMediaBlur"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_protected_media_mode_blur" />
            </RadioGroup>
        </LinearLayout>

        <TextView
            android:id="@+id/tvAutoLockTimeoutTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/security_auto_lock_timeout"
            android:textColor="@color/app_on_surface"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgAutoLockTimeout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/radioLockInstant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/security_lock_instant" />

            <RadioButton
                android:id="@+id/radioLockAfter30Sec"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/security_lock_30s" />

            <RadioButton
                android:id="@+id/radioLockAfter1Min"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/security_lock_1m" />

            <RadioButton
                android:id="@+id/radioLockAfter5Min"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/security_lock_5m" />
        </RadioGroup>
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="?attr/selectableItemBackground">

    <ImageView
        android:id="@+id/ivProviderIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_cloud_24"
        app:tint="@color/app_on_surface"
        android:contentDescription="@string/cloud_provider" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAccountName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/app_on_surface"
            android:textSize="15sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvAccountDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/app_on_surface_secondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvLastSync"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/app_on_surface_secondary"
            android:textSize="11sp"
            android:layout_marginTop="2dp"
            android:singleLine="true" />
    </LinearLayout>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switchEnabled"
        style="@style/Widget.Galerinio.Cloud.Switch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp" />

</LinearLayout>


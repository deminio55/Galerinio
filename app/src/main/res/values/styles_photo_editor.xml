<resources>
    <style name="Widget.Galerinio.PhotoEditor.ToolButton.OutlinedText" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/photo_editor_tool_on_surface</item>
        <item name="backgroundTint">@color/photo_editor_tool_surface</item>
        <item name="strokeColor">@color/photo_editor_tool_stroke</item>
    </style>

    <style name="Widget.Galerinio.PhotoEditor.ToolButton.OutlinedIcon" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="iconTint">@color/photo_editor_tool_on_surface</item>
        <item name="backgroundTint">@color/photo_editor_tool_surface</item>
        <item name="strokeColor">@color/photo_editor_tool_stroke</item>
    </style>

    <style name="Widget.Galerinio.PhotoEditor.ToolButton.OutlinedIconNoTint" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="backgroundTint">@color/photo_editor_tool_surface</item>
        <item name="strokeColor">@color/photo_editor_tool_stroke</item>
    </style>

    <style name="Widget.Galerinio.PhotoEditor.TextToolbar.ButtonText" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/photo_editor_tool_on_surface</item>
        <item name="backgroundTint">@color/photo_editor_tool_stroke</item>
        <item name="strokeColor">@color/photo_editor_toolbar_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="elevation">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.Galerinio.PhotoEditor.TextToolbar.ButtonIcon" parent="Widget.MaterialComponents.Button.Icon">
        <item name="iconTint">@color/photo_editor_tool_on_surface</item>
        <item name="backgroundTint">@color/photo_editor_tool_stroke</item>
        <item name="strokeColor">@color/photo_editor_toolbar_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">10dp</item>
        <item name="elevation">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="Widget.Galerinio.PhotoEditor.TextToolbar.ButtonIconNoTint" parent="Widget.Galerinio.PhotoEditor.TextToolbar.ButtonIcon">
        <item name="iconTint">@null</item>
        <item name="elevation">0dp</item>
    </style>
</resources>

